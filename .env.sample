DATABASE_URL="postgresql://{{project-name}}:{{project-name}}@localhost:5432/{{project-name}}?schema=public"
AUTH_SECRET="your-auth-secret-here"

# Google OAuth（https://console.cloud.google.com/apis/credentials）
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# 本番用（.env.production に設定）
# DATABASE_URL="postgresql://..." (pooled - アプリ用)
# DATABASE_URL_UNPOOLED="postgresql://..." (unpooled - マイグレーション/シード用)
